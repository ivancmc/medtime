# MedTime — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
VITE_SUPABASE_ANON_KEY="<YOUR_ANON_KEY>"

# ── VAPID Keys ────────────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# The PUBLIC key goes in both the frontend (VITE_) and Supabase secrets.
# The PRIVATE key goes ONLY in Supabase secrets — never expose it here.

VITE_VAPID_PUBLIC_KEY="<YOUR_VAPID_PUBLIC_KEY>"

# ── Legacy / Dev ──────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
